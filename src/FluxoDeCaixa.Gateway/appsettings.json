{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Clusters": {
      "mainApiCluster": {
        "Destinations": { "mainApiDestination": { "Address": "http://localhost:8000" } },
        "HttpRequest": {
          "Version": "1.1",
          "VersionPolicy": "RequestVersionExact"
        }
      },
      "relatorioApiCluster": {
        "Destinations": { "relatorioApiDestination": { "Address": "http://localhost:8500" } },
        "HttpRequest": {
          "Version": "1.1",
          "VersionPolicy": "RequestVersionExact"
        }
      }
    },
    "Routes": {
      // 1. Rota para o Swagger da API de Fluxo de Caixa
      "mainApiSwaggerRoute": {
        "ClusterId": "mainApiCluster",
        "Match": { "Path": "/fluxodecaixa/swagger/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/fluxodecaixa" } ]
      },
      // 2. Rota para o Swagger da API de Relatórios
      "relatorioApiSwaggerRoute": {
        "ClusterId": "relatorioApiCluster",
        "Match": { "Path": "/relatorio/swagger/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/relatorio" } ]
      },
      // 3. Rota para os endpoints de negócio de Relatórios
      "relatorioApiRoute": {
        "ClusterId": "relatorioApiCluster",
        "Match": { "Path": "/api/FluxoDeCaixaRelatorio/{**catch-all}" }
      },
      // 4. Rota genérica para a API principal
      // O 'Order' alto garante que não interfira nos arquivos locais do Gateway
      "mainApiRoute": {
        "ClusterId": "mainApiCluster",
        "Order": 200,
        "Match": { "Path": "/{**catch-all}" },
        "Metadata": { "non-proxy-paths": " /swagger" }
      }
    }
  }
}